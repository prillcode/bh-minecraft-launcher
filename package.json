{
  "name": "blockhaven-launcher",
  "version": "1.0.0",
  "description": "Custom Minecraft launcher with Microsoft auth, multi-instance support, and mod management",
  "main": "dist/main/index.js",
  "author": {
    "name": "AP Dev Solutions LLC",
    "email": "prillcode@gmail.com"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:main\" \"pnpm dev:renderer\"",
    "dev:all": "pnpm build:main && concurrently \"pnpm dev\" \"wait-on http://localhost:5173 && pnpm start\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite dev src/renderer",
    "build": "pnpm build:main && pnpm build:renderer",
    "build:main": "vite build --config vite.main.config.ts",
    "build:renderer": "vite build",
    "start": "electron dist/main/index.js",
    "package": "electron-builder --config electron-builder.yml --publish never",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.0",
    "checksum": "^1.0.0",
    "dotenv": "^17.3.1",
    "electron-store": "^10.0.0",
    "extract-zip": "^2.0.1",
    "framer-motion": "^12.0.0",
    "got": "^14.4.0",
    "lucide-react": "^0.469.0",
    "p-queue": "^8.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "remark-gfm": "^4.0.1",
    "winston": "^3.17.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.17.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^9.0.4"
  }
}
